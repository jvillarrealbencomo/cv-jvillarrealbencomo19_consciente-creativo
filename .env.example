# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# Upload Limits (bytes)
MAX_CONTENT_LENGTH=5242880

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database (SQLite default - change for PostgreSQL in production)
# DATABASE_URL=sqlite:///instance/cv_database.db
# DATABASE_URL=postgresql://user:password@localhost/cv_db
