# Environment Configuration Template
# Copy this file to .env and update with your values

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database (optional, defaults to SQLite)
# DEV_DATABASE_URL=sqlite:///cv_dev.db
# DATABASE_URL=sqlite:///cv_prod.db

# For 2026 PostgreSQL migration:
# DATABASE_URL=postgresql://user:password@localhost:5432/cv_db

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Application Settings
APP_NAME=Professional CV Application
APP_VERSION=2.0.0

# Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# 2026 Vision: AI API Keys
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# 2026 Vision: Email Configuration
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-password
