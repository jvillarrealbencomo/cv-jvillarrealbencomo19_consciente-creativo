# .dockerignore
# Exclude files from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/
dist/
build/

# Flask
instance/
.webassets-cache

# Database
*.db
*.sqlite
*.sqlite3
cv_dev.db
cv_prod.db

# Environment
.env
.env.local

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs
logs/
*.log

# Generated files
generated_pdfs/
uploads/

# Node (if using frontend tools)
node_modules/
npm-debug.log

# Temporary files
tmp/
temp/
